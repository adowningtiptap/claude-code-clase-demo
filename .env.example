# ── Supabase (app) ───────────────────────────────────────
# Las escribe /setup automáticamente después de crear el proyecto.
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# ── Tokens para el agente (NO se commitea — .env.local está en .gitignore) ──
# /setup y /deploy los usan para crear el proyecto y desplegar vía API.
# Pégalos cuando el agente te los pida. REVÓCALOS al terminar la clase.
#   Supabase: https://supabase.com/dashboard/account/tokens   (empieza con sbp_)
#   Vercel:   https://vercel.com/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_tu-access-token
VERCEL_TOKEN=tu-vercel-token
